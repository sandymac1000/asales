# Supabase — create a project at supabase.com, copy from Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# The publishable/anon key (Project Settings > API > Project API keys)
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key
# The service_role key — SERVER ONLY, never expose to the browser.
# Used to read/write org_secrets (per-org Anthropic keys), which RLS hides from clients.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Master secret used to encrypt org Anthropic keys at rest (AES-256-GCM).
# Any long random string; keep it stable or stored keys become undecryptable.
KEY_ENCRYPTION_SECRET=generate-a-long-random-string

# Feedback email delivery (Resend). Create a key at resend.com.
# Sends from onboarding@resend.dev, so it works to your own address with no domain setup.
RESEND_API_KEY=re_...
FEEDBACK_EMAIL=you@example.com

# App URL — used for magic-link auth redirects. In production, the Vercel URL.
NEXT_PUBLIC_APP_URL=http://localhost:3007

# Operator console (/admin). Comma-separated emails granted the whole-system
# operator view (all orgs' usage metadata + provisioning). Keep this to you only —
# it is NOT per-portfolio scoped.
ADMIN_EMAILS=you@example.com
# Optional: verified Resend sender for invite emails to external recipients.
# Until set, invites fall back to onboarding@resend.dev (reaches your inbox only)
# and the provision form shows the code to pass on manually.
# INVITE_FROM_EMAIL=Salient <invites@yourdomain.com>

# NOTE: There is no app-wide ANTHROPIC_API_KEY any more. Each organisation
# supplies its own key in Settings > AI access, so LLM usage is billed to them.
